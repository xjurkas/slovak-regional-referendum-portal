<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.oop.referendumserver.view.controllers.ReferendumResultViewController"
            prefHeight="400.0" prefWidth="600.0">
    <fx:include source="navigate-buttons.fxml" fx:id="navigation" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>
    <VBox alignment="CENTER" spacing="20.0" AnchorPane.topAnchor="70" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Label text="Vyberte region"/>
        <ComboBox fx:id="regionSelectComboBox" onAction="#handleRegionSelection" />
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
        <ListView fx:id="resultListView"/>
    </VBox>
</AnchorPane>
