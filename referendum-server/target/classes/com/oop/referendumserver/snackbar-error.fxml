<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox maxHeight="60.0" minHeight="60" prefHeight="60.0" prefWidth="500.0" minWidth="500" maxWidth="500" spacing="10"
      styleClass="snackbar-toast" stylesheets="@CSS/styles.css" xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1">
    <ImageView fitHeight="35.0" fitWidth="35.0" preserveRatio="true">
        <Image url="@images/error.png"/>
    </ImageView>
    <Label id="errorLabel" alignment="CENTER" minHeight="35" prefHeight="35.0" prefWidth="500" text="Unexpected error occured !"
           textAlignment="CENTER" wrapText="true"/>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

</HBox>
